      "act": 3,
      "act_title": "Rejection",
      "on_screen": "Rejected: privacy + latency",
      "narration": "We rejected that. Audio leaving Vision Pro kills privacy \u2014 latency becomes whatever the network feels like. For accessibility, unpredictable delay is as bad as wrong text.",
      "word_count": 27,
      "target_seconds": 11.6,
      "source": "draft"
    },
