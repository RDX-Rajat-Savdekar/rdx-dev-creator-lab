    {
      "chapter": 4,
      "chapter_title": "Segmentation",
      "youtube_chapter": "Segmentation",
      "act": 1,
      "act_title": "formattedString problem",
      "on_screen": "Wall of text",
      "narration": "Speech recognition returns a formatted string \u2014 one continuous dump. No pauses, no sentences, no structure. During a live conversation it becomes an unreadable wall of text on screen.",
      "word_count": 29,
      "target_seconds": 12.4,
      "source": "seed"
    },
    {
      "chapter": 4,
      "chapter_title": "Segmentation",
      "youtube_chapter": "Segmentation",
      "act": 2,
      "act_title": "Pause threshold",
      "on_screen": "Pause gap: 1.1 s",
      "narration": "First layer: temporal segmentation. When the speaker pauses longer than 1.1 seconds, we treat that as a new utterance \u2014 a breath between thoughts or between speakers.",
      "word_count": 27,
      "target_seconds": 11.6,
      "source": "seed"
    },
    {
      "chapter": 4,
      "chapter_title": "Segmentation",
      "youtube_chapter": "Segmentation",
      "act": 3,
      "act_title": "Sentence splitter",
      "on_screen": "Sentence splitter",
      "narration": "Second layer: grammatical splitting. Abbreviations like Dr. and e.g. stay intact \u2014 we only break on real sentence boundaries. One utterance in, clean sentence chips out.",
      "word_count": 26,
      "target_seconds": 11.1,
      "source": "seed"
    },
    {
      "chapter": 4,
      "chapter_title": "Segmentation",
      "youtube_chapter": "Segmentation",
      "act": 4,
      "act_title": "Before/after + D2",
      "on_screen": "Readable captions",
      "narration": "Before: one blob. After: utterance-to-sentence chunks you can actually read while someone is talking. The two-layer split fixed readability \u2014 and it holds up with multiple speakers.",
      "word_count": 27,
      "target_seconds": 11.6,
      "source": "seed"
    },
    {
      "chapter": 5,
      "chapter_title": "Texture HUD vs 90 Hz",
      "youtube_chapter": "Texture HUD vs 90 Hz",
      "act": 1,
      "act_title": "90 Hz ViewAttachment",
      "on_screen": "90 Hz \u00b7 layout every frame",
      "narration": "RealityKit runs at 90 Hz. Hooking captions via ViewAttachment means SwiftUI re-layout on every frame \u2014 layout cost tied directly to the render loop. We marked this path rejected.",
      "word_count": 29,
      "target_seconds": 12.4,
      "source": "seed"
    },
    {
      "chapter": 5,
      "chapter_title": "Texture HUD vs 90 Hz",
      "youtube_chapter": "Texture HUD vs 90 Hz",
      "act": 2,
      "act_title": "Texture bake pipeline",
      "on_screen": "Texture bake \u00b7 100 ms",
      "narration": "Off-screen bake: render captions in SwiftUI, snapshot to a texture, composite on a lightweight RK quad in the scene. Debounce rebakes to 100 milliseconds so partial transcripts don't thrash the GPU.",
      "word_count": 31,
      "target_seconds": 13.3,
      "source": "seed"
    },
    {
      "chapter": 5,
      "chapter_title": "Texture HUD vs 90 Hz",
      "youtube_chapter": "Texture HUD vs 90 Hz",
      "act": 3,
      "act_title": "Jitter vs baked",
      "on_screen": "Jitter vs baked quad",
      "narration": "Same caption content \u2014 different render path. Per-frame layout jitters the HUD; the baked texture stays pinned. Watch the left panel wobble while the right stays stable.",
      "word_count": 27,
      "target_seconds": 11.6,
      "source": "seed"
    },
    {
      "chapter": 5,
      "chapter_title": "Texture HUD vs 90 Hz",
      "youtube_chapter": "Texture HUD vs 90 Hz",
      "act": 4,
      "act_title": "Honesty card",
      "on_screen": "2D HUD shipped in demo",
      "narration": "What we actually shipped in the demo: a 2D HUD overlay \u2014 not the full world-space texture path. Honest about the gap between prototype and production.",
      "word_count": 26,
      "target_seconds": 11.1,
      "source": "seed"
    },
    {
      "chapter": 6,
      "chapter_title": "MainActor bridge",
      "youtube_chapter": "MainActor bridge",
      "act": 1,
      "act_title": "ML callback off main thread",
      "on_screen": "Background thread \u00b7 ML result",
      "narration": "Speech and sound delegates fire on background threads \u2014 not on MainActor. ML results arrive while the tap keeps running on the audio thread from chapter three.",
      "word_count": 27,
      "target_seconds": 11.6,
      "source": "seed"
    },
    {
      "chapter": 6,
      "chapter_title": "MainActor bridge",
      "youtube_chapter": "MainActor bridge",
      "act": 2,
      "act_title": "@Published mutation rule",
      "on_screen": "MainActor \u00b7 UI updates",
      "narration": "Any @Published property that drives SwiftUI must mutate on MainActor. We wrap caption updates in Task { @MainActor in } so the panel refreshes safely.",
      "word_count": 25,
      "target_seconds": 10.7,
      "source": "seed"
    },
    {
      "chapter": 6,
      "chapter_title": "MainActor bridge",
      "youtube_chapter": "MainActor bridge",
      "act": 3,
      "act_title": "Why it matters for captions",
      "on_screen": "Captions update on main",
      "narration": "That's why live captions can refresh on screen while classification keeps streaming \u2014 UI work hops to main; the tap never waits.",
      "word_count": 22,
      "target_seconds": 9.4,
      "source": "seed"
    },
    {
      "chapter": 7,
      "chapter_title": "Directional pins \u2192 Iron Man HUD",
      "youtube_chapter": "Iron Man HUD",
      "act": 1,
      "act_title": "Tried world-locked pins",
      "on_screen": "Tried: world-locked pins",
      "narration": "Early on we tried pinning each sound to the direction it came from \u2014 markers in the world where audio seemed to originate.",
      "word_count": 23,
      "target_seconds": 9.9,
